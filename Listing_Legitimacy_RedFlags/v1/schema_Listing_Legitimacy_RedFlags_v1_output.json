{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Listing_Legitimacy_RedFlags_v1_output",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "legitimacyStatus": {
      "type": "string",
      "enum": ["LEGIT_LIKELY", "SCAM_LIKELY", "UNKNOWN", "NEEDS_VERIFICATION"]
    },
    "riskLevel": { "type": "string", "enum": ["LOW", "MED", "HIGH"] },
    "riskScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "redFlags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["LOW", "MED", "HIGH"] },
          "evidence": { "type": "string" }
        },
        "required": ["code", "severity", "evidence"]
      }
    },
    "nextSteps": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["legitimacyStatus", "riskLevel", "riskScore", "redFlags", "nextSteps", "notes"]
}
