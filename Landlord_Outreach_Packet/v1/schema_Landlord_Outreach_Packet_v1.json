{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Landlord_Outreach_Packet_v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["address", "rentToOwner", "utilitiesPaidBy", "contact"],
      "properties": {
        "address": { "type": "string", "minLength": 1 },
        "rentToOwner": { "type": "number", "minimum": 0 },
        "utilitiesPaidBy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["electric", "gas", "water", "sewer", "trash"],
          "properties": {
            "electric": { "type": "string", "enum": ["tenant", "owner", "unknown"] },
            "gas": { "type": "string", "enum": ["tenant", "owner", "unknown"] },
            "water": { "type": "string", "enum": ["tenant", "owner", "unknown"] },
            "sewer": { "type": "string", "enum": ["tenant", "owner", "unknown"] },
            "trash": { "type": "string", "enum": ["tenant", "owner", "unknown"] },
            "internet": { "type": "string", "enum": ["tenant", "owner", "unknown"], "default": "unknown" }
          }
        },
        "contact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "role", "phone", "email"],
          "properties": {
            "name": { "type": ["string", "null"] },
            "role": { "type": "string", "enum": ["owner", "property_manager", "agent", "unknown"] },
            "phone": { "type": ["string", "null"] },
            "email": { "type": ["string", "null"] }
          }
        },
        "notes": { "type": ["string", "null"] }
      }
    },

    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": ["programType", "zip"],
      "properties": {
        "programType": { "type": "string", "enum": ["HUD-VASH", "HCV", "Section8", "Other"] },
        "zip": { "type": "string", "minLength": 3 },
        "phaName": { "type": ["string", "null"] },
        "phaCity": { "type": ["string", "null"] }
      }
    },

    "programGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["programGateStatus"],
      "properties": {
        "programGateStatus": { "type": "string", "enum": ["PASS", "FAIL", "UNKNOWN", "FAIL_PENDING_PHA"] },
        "grossRent": { "type": ["number", "null"], "minimum": 0 },
        "utilityAllowance": { "type": ["number", "null"], "minimum": 0 },
        "tenantShare": { "type": ["number", "null"], "minimum": 0 },
        "initialRentBurden": { "type": ["number", "null"], "minimum": 0 },
        "approvalBedroomCapSizeUsed": { "type": ["integer", "null"], "minimum": 0 },
        "rentReasonablenessRisk": { "type": ["string", "null"], "enum": ["LOW", "MED", "HIGH", "UNKNOWN", null] },
        "actionsRequired": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },

    "legitimacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legitimacyStatus"],
      "properties": {
        "legitimacyStatus": { "type": "string", "enum": ["LEGIT_LIKELY", "SCAM_LIKELY", "UNKNOWN", "NEEDS_VERIFICATION"] },
        "riskLevel": { "type": ["string", "null"], "enum": ["LOW", "MED", "HIGH", null] },
        "riskScore": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "redFlags": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "code": { "type": "string" },
              "severity": { "type": "string", "enum": ["LOW", "MED", "HIGH"] },
              "evidence": { "type": "string" }
            },
            "required": ["code", "severity", "evidence"]
          }
        },
        "nextSteps": { "type": "array", "items": { "type": "string" } }
      }
    },

    "hqs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hqsStatus"],
      "properties": {
        "hqsStatus": { "type": "string", "enum": ["PASS_LIKELY", "FAIL_LIKELY", "UNKNOWN", "PASS_WITH_FIXES"] },
        "failReasons": { "type": "array", "items": { "type": "string" } },
        "fixableItems": { "type": "array", "items": { "type": "string" } },
        "unknownItems": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "required": ["unit", "program", "programGate", "legitimacy", "hqs"]
}
