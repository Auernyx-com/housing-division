{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HQS_PreInspection_Screener_v1",
  "type": "object",
  "properties": {
    "unit": {
      "type": "object",
      "required": [
        "address",
        "unitType",
        "bedroomsAdvertised",
        "utilities",
        "ventilation",
        "safety",
        "conditionSignals",
        "photosProvided"
      ],
      "properties": {
        "address": { "type": "string" },
        "unitType": {
          "type": "string",
          "enum": ["apartment", "house", "townhome", "mobile", "tinyhome"]
        },
        "listingUrl": { "type": ["string", "null"] },
        "bedroomsAdvertised": { "type": "integer", "minimum": 0 },
        "bathroomsAdvertised": { "type": ["number", "null"] },
        "sqft": { "type": ["integer", "null"], "minimum": 0 },
        "yearBuilt": { "type": ["integer", "null"], "minimum": 1600 },
        "floorLevel": { "type": ["integer", "null"] },
        "hasBasementBedroom": { "type": ["boolean", "null"] },

        "utilities": {
          "type": "object",
          "required": [
            "hasWorkingHeat",
            "heatSource",
            "heatProvidedBy",
            "hotWater",
            "cookingAppliance",
            "oven",
            "washerDryer"
          ],
          "properties": {
            "hasWorkingHeat": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "heatSource": {
              "type": "string",
              "enum": ["forced_air", "baseboard", "wall_heater", "mini_split", "wood", "unknown"]
            },
            "heatProvidedBy": { "type": "string", "enum": ["landlord", "tenant", "unknown"] },
            "hotWater": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "cookingAppliance": { "type": "string", "enum": ["stove", "hotplate", "none", "unknown"] },
            "oven": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "washerDryer": { "type": "string", "enum": ["in_unit", "on_site", "none", "unknown"] }
          }
        },

        "ventilation": {
          "type": "object",
          "required": ["bathroomHasWindow", "bathroomHasFanDuctedOutside", "kitchenHasVent"],
          "properties": {
            "bathroomHasWindow": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "bathroomHasFanDuctedOutside": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "kitchenHasVent": {
              "type": "string",
              "enum": ["hood_ducted", "hood_recirculating", "none", "unknown"]
            }
          }
        },

        "safety": {
          "type": "object",
          "required": [
            "smokeDetectors",
            "coDetectors",
            "gfciInKitchenBath",
            "handrailsOnStairs",
            "exteriorDoorDeadbolt",
            "egressWindowsInBedrooms"
          ],
          "properties": {
            "smokeDetectors": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "coDetectors": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "gfciInKitchenBath": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "handrailsOnStairs": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "exteriorDoorDeadbolt": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "egressWindowsInBedrooms": { "type": "string", "enum": ["yes", "no", "unknown"] }
          }
        },

        "conditionSignals": {
          "type": "object",
          "required": [
            "visibleMold",
            "pestSigns",
            "brokenWindows",
            "exposedWiring",
            "missingOutletCovers",
            "leaksWaterDamage"
          ],
          "properties": {
            "visibleMold": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "pestSigns": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "brokenWindows": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "exposedWiring": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "missingOutletCovers": { "type": "string", "enum": ["yes", "no", "unknown"] },
            "leaksWaterDamage": { "type": "string", "enum": ["yes", "no", "unknown"] }
          }
        },

        "photosProvided": { "type": "integer", "minimum": 0 },
        "notesText": { "type": ["string", "null"] }
      }
    }
  },
  "required": ["unit"]
}
